# ============================================================================
# Villa Sarita — environment variables
# ============================================================================
# Copy this file to .env.local and fill in real values for local dev.
# In production (Vercel), paste each line into the dashboard under
# Project Settings → Environment Variables. Never commit .env.local to git.
# ============================================================================


# ----------------------------------------------------------------------------
# [1] Site — used for redirect URLs back from Wompi after payment
# ----------------------------------------------------------------------------
# Local dev:  http://localhost:3000
# Production: https://villasaritaecolodge.com (or whatever the live domain is)
NEXT_PUBLIC_SITE_URL=


# ----------------------------------------------------------------------------
# [2] Wompi — payment processor (https://comercios.wompi.co)
# ----------------------------------------------------------------------------
# Steps:
#   1. Register a Wompi merchant account
#   2. Switch to TEST mode while developing — replace with prod keys at launch
#   3. After deploying, add the events webhook URL in the Wompi dashboard:
#        https://villasaritaecolodge.com/api/webhook/wompi
# Public key format:    pub_test_…  (test)  or  pub_prod_…  (production)
# Private key format:   prv_test_…  /  prv_prod_…
# WOMPI_ENV values:     sandbox  |  production
NEXT_PUBLIC_WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_ENV=


# ----------------------------------------------------------------------------
# [3] Resend — transactional email notifications to auntie
# ----------------------------------------------------------------------------
# - Used to email auntie when a booking is paid.
# - Optional: if not configured, bookings still save to disk + show in /admin,
#   and auntie gets the WhatsApp notification (if [4] is configured).
# - RESEND_FROM_EMAIL must be from a domain verified inside your Resend account.
# - HOST_NOTIFY_EMAIL is the inbox that receives new-booking alerts.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
HOST_NOTIFY_EMAIL=


# ----------------------------------------------------------------------------
# [4] WhatsApp Cloud API — push notifications to auntie's phone (RECOMMENDED)
# ----------------------------------------------------------------------------
# Free tier covers ~1000 conversations/month — plenty for a small ecolodge.
#
# Setup (~30 min):
#   1. https://developers.facebook.com/ → create a Meta app
#   2. Add the "WhatsApp" product
#   3. Add a test phone number, or verify your real business number
#   4. Copy "Phone Number ID" and "System User Access Token"
#   5. Add auntie's number as a recipient
#
# HOST_WHATSAPP_NUMBER format: E.164, digits only, no "+" (e.g. country code
# + number with no separators).
#
# Optional. If not set, the booking flow still works — auntie just gets the
# email instead (assuming [3] is set).
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=
HOST_WHATSAPP_NUMBER=


# ----------------------------------------------------------------------------
# [5] Admin page — auntie's "view bookings" URL
# ----------------------------------------------------------------------------
# Generate a long random string. This IS the password — anyone with the URL
# can see all bookings.
#
# Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Auntie's bookmark URL becomes:
#   https://villasaritaecolodge.com/admin/reservas?token=<the value below>
ADMIN_TOKEN=


# ----------------------------------------------------------------------------
# [6] Booking store — where the JSON file lives (optional)
# ----------------------------------------------------------------------------
# Default: ./data/bookings.json relative to the project root.
# Set this to a writable, persistent path on your server if needed.
#
# WARNING for serverless platforms (Vercel/Netlify): the filesystem is
# ephemeral. Before deploying there, swap lib/bookingStore.ts to use Vercel
# Postgres / Vercel KV / Upstash Redis instead of a JSON file.
BOOKING_STORE_PATH=
