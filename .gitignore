# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# persisted booking data — contains guest PII, never commit
/data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Heavy reference materials — business assets, not source code.
# Keep these locally and/or in Google Drive, but don't bloat the repo.
/Fotografías/
/Manual de Marca*.pdf
/Catálogo Hospedaje*.pdf
*.pdf

# Stray screenshots / pasted images that sometimes land in the project root
# from drag-and-drop — never commit these (often contain WhatsApp chats etc.)
/WhatsApp Image*.jpeg
/WhatsApp Image*.jpg
/WhatsApp Image*.png
/Screenshot*.png
/Captura de pantalla*.png
*:Zone.Identifier
